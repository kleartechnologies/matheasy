<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Sign in with Apple (Stage 7). This file is ready to use; to activate it,
	  open ios/Runner.xcworkspace in Xcode and add Signing & Capabilities →
	  "Sign in with Apple" to the Runner target (Xcode links this entitlements
	  file to the build automatically). See SETUP_FIREBASE.md.
	-->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
