<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash: the official brand tile (emerald field + white M + shadow)
     centred on the brand background. The tile carries its own colours, so it is
     NOT tinted — the same raster shows on both the light and values-night
     backgrounds. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_background" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launch_image" />
    </item>
</layer-list>
