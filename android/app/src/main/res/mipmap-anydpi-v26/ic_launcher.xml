<?xml version="1.0" encoding="utf-8"?>
<!-- The foreground is the rendered brand artwork (white M + deep-forest outline +
     long shadow) inset into the safe zone; the flat-emerald <background> bleeds
     through its transparent margin. <monochrome> is a SEPARATE single-tone M
     silhouette — the artwork's green field would theme to a solid blob. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_monochrome" />
</adaptive-icon>
