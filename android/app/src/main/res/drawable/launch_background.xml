<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash: the brand mark centred on the brand background. Kept in sync
     with drawable-v21/launch_background.xml — minSdk is 23, so that copy is the
     one that actually resolves; this exists only to satisfy the base drawable/. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_background" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launch_image"
            android:tint="@color/launch_mark" />
    </item>
</layer-list>
